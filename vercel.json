{
  "version": 2,
  "builds": [
    { "src": "backend/api/index.js", "use": "@vercel/node" },
    { "src": "dashboard/public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/api/index.js" },
    { "src": "/$", "dest": "dashboard/public/index.html" },
    { "src": "/(.*)", "dest": "dashboard/public/$1" }
  ]
}
