# --- Required ---
# Your Discord bot token (Discord Developer Portal → your app → Bot → Reset Token).
DISCORD_TOKEN=

# Your server (guild) ID, so slash commands register INSTANTLY to your server.
# Enable Developer Mode (Discord Settings → Advanced), then right-click your
# server icon → Copy Server ID. Leave blank to register globally (~1h to appear).
GUILD_ID=

# --- Backend ---
# Where the shared backend is running.
BACKEND_URL=http://localhost:3001

# --- Optional: proactive alerts (bonus) ---
# Channel ID to post alerts into (right-click a channel → Copy Channel ID).
# Leave blank to disable.
ALERT_CHANNEL_ID=
# How often to check for new alerts, in milliseconds (default 60000).
ALERT_POLL_MS=60000

# --- Optional: LLM-phrased replies ---
# Set LLM_PROVIDER to "anthropic" or "openai" to warm up replies; leave as
# "none" (or unset) to use the built-in friendly wording with no API calls.
LLM_PROVIDER=none
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Override the model if you like (defaults: claude-3-5-haiku-latest / gpt-4o-mini).
LLM_MODEL=
